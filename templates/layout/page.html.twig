{#
/**
 * @file
 * Theme override to display a single page.
 *
 * The doctype, html, head and body tags are not in this template. Instead they
 * can be found in the html.html.twig template normally located in the
 * core/modules/system directory.
 *
 * Available variables:
 *
 * General utility variables:
 * - base_path: The base URL path of the Drupal installation. Will usually be
 *   "/" unless you have installed Drupal in a sub-directory.
 * - is_front: A flag indicating if the current page is the front page.
 * - logged_in: A flag indicating if the user is registered and signed in.
 * - is_admin: A flag indicating if the user has permission to access
 *   administration pages.
 * - component_containers: Boolean indicating whether to use component-based
 *   containers (TRUE) or a single page-level container (FALSE).
 *
 * Site identity:
 * - front_page: The URL of the front page. Use this instead of base_path when
 *   linking to the front page. This includes the language domain or prefix.
 *
 * Page content (in order of occurrence in the default page.html.twig):
 * - node: Fully loaded node, if there is an automatically-loaded node
 *   associated with the page and the node ID is the second argument in the
 *   page's path (e.g. node/12345 and node/12345/revisions, but not
 *   comment/reply/12345).
 *
 * Regions:
 * - page.top_bar: Items for Top Bar region
 * - page.header: Items for the header region.
 * - page.navigation: Items for the navigation region.
 * - page.breadcrumb: Items for the breadcrumb region.
 * - page.hero: Items for the hero content region.
 * - page.system: Admin related items like help, tabs, messages.
 * - page.top: Items for the Top content region.
 * - page.content: The main content of the current page.
 * - page.bottom: Items for the Bottom content region.
 * - page.sidebar_first: Items for the first sidebar.
 * - page.sidebar_second: Items for the second sidebar.
 * - page.footer: Items for the footer region.
 * - page.admin: Items for the admin tools region
 * - component_containers: Boolean indicating whether to use component-based
 *   containers (TRUE) or a single page-level container (FALSE).
 * - sticky_header: Header sticky behavior. Options: FALSE (normal),
 *   'sticky' (always visible), 'auto-hide' (hides on scroll down, shows on scroll up).
 *
 * @see template_preprocess_page()
 * @see html.html.twig
 */
#}

{#
  Attaching Drupal libraries
#}
{% block includes %}
{% endblock %}

{#
  Defining local variables
#}
{% set page_classes = [
  'c-page',
] %}

{#
  Building the template structure
#}
<div{{ attributes.addClass(page_classes) }} id="c-page">
  {% if page.top_bar or page.header or page.navigation %}
    {{ attach_library('brainsum_starterkit/header') }}

    <header id="c-header" class="c-header{{ sticky_header ? ' is-sticky is-sticky--' ~ sticky_header }}" data-drupal-selector="header">
      {% if page.top_bar %}
        <div class="c-top-bar" data-drupal-selector="top-bar">
          <div class="o-container">
            {{ page.top_bar }}
          </div>
        </div>
      {% endif %}

      {% if page.header %}
        <div class="o-container">
          {{ page.header }}
        </div>
      {% endif %}

      {% if page.navigation %}
        <div class="o-container">
          <div class="c-navigation__grid">
            <div class="c-header__navigation" id="c-header__navigation" data-drupal-selector="header__navigation">
              {{ page.navigation }}
            </div>

            <button
              class="c-header__hamburger c-hamburger"
              data-drupal-selector="hamburger"
              aria-controls="c-header__navigation"
              aria-expanded="false"
            >
              <span class="c-hamburger__box">
                <span class="c-hamburger__spinner"></span>
              </span>

              <span class="c-hamburger__label u-visually-hide">{{ 'Toggle Main Menu'|t }}</span>
            </button>
          </div>
        </div>
      {% endif %}
    </header>
  {% endif %}

  <main id="main">
    {% if not component_containers %}
      <div class="o-container">
    {% endif %}

    {# Skip link for keyboard users #}
    <div class="c-skip-link__target">
      {% if component_containers %}
        <div class="o-container">
      {% endif %}
        {# you can find the link in html.html.twig #}
        <span id="main-content" tabindex="-1" class="u-visually-hide u-visually-hide--focusable">
          {{ 'Main content'|t }}
        </span>
      {% if component_containers %}
        </div>
      {% endif %}
    </div>

    {% if page.breadcrumb %}
      <div class="c-breadcrumb__section">
        {% if component_containers %}
          <div class="o-container">
        {% endif %}
          {{ page.breadcrumb }}
        {% if component_containers %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if page.hero %}
      <div class="c-hero">
        {% if component_containers %}
          <div class="o-container">
        {% endif %}
          {% block hero_region %}
            {{ page.hero }}
          {% endblock %}
        {% if component_containers %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if page.system %}
      <div class="c-system">
        {% if component_containers %}
          <div class="o-container">
        {% endif %}
          {{ page.system }}
        {% if component_containers %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if page.top %}
      <div class="c-top">
        {% if component_containers %}
          <div class="o-container">
        {% endif %}
          {{ page.top }}
        {% if component_containers %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="c-content">
      {% block content_region %}
        {{ page.content }}
      {% endblock %}
    </div>

    {% if page.sidebar %}
      <div class="c-sidebar c-sidebar--first">
        {{ page.sidebar }}
      </div>
    {% endif %}

    {% if page.sidebar_second %}
      <div class="c-sidebar c-sidebar--second">
        {{ page.sidebar_second }}
      </div>
    {% endif %}

    {% if page.bottom %}
      <div class="c-bottom">
        {% if component_containers %}
          <div class="o-container">
        {% endif %}
          {{ page.bottom }}
        {% if component_containers %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if not component_containers %}
      </div>
    {% endif %}
  </main>

  <footer class="c-footer">
    <div class="o-container">
      {% if page.footer %}
        {{ page.footer }}
      {% endif %}
    </div>
  </footer>

  <div class="c-overlay" data-drupal-selector="overlay"></div>
</div>

{{ page.admin }}
