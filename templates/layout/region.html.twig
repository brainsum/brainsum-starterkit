{#
/**
 * @file
 * Theme override to display a region.
 *
 * Available variables:
 * - content: The content for this region, typically blocks.
 * - attributes: HTML attributes for the region <div>.
 * - region: The name of the region variable as defined in the theme's
 *   .info.yml file.
 * - component_containers: Boolean indicating whether to use component-based
 *   containers (TRUE) or a single page-level container (FALSE).
 * - sticky_header: Header sticky behavior. Options: FALSE (normal),
 *   'sticky' (always visible), 'auto-hide' (hides on scroll down, shows on scroll up).
 *
 * @see template_preprocess_region()
 */
#}

{#
  Defining local variables
#}
{% set classes = [
  'c-region',
  'c-region--' ~ region|clean_class,
] %}

{#
  Building the template structure
#}
{% if content %}
  <div{{ attributes.addClass(classes) }}>
    {{ content }}
  </div>
{% endif %}
