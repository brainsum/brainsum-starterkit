{#
/**
 * @file
 * Theme override to display a pager.
 *
 * Configuration:
 * To customize pager behavior, edit settings/settings.pager.yml:
 * - use_heading: Whether to use semantic heading or <div> for pager label.
 *   Default is false (uses <div>) because pagers are navigation elements,
 *   not content sections. Using headings pollutes the document outline with
 *   repetitive navigation that appears on multiple pages. Accessibility is
 *   maintained via aria-labelledby. Set to true only if you specifically
 *   need pager labels in the document outline.
 * - use_link_labels: Whether to use text labels or SVG icons for navigation
 *
 * Available variables:
 * - heading_id: Pagination heading ID.
 * - items: List of pager items.
 *   The list is keyed by the following elements:
 *   - first: Item for the first page; not present on the first page of results.
 *   - previous: Item for the previous page; not present on the first page
 *     of results.
 *   - next: Item for the next page; not present on the last page of results.
 *   - last: Item for the last page; not present on the last page of results.
 *   - pages: List of pages, keyed by page number.
 *   Sub-sub elements:
 *   items.first, items.previous, items.next, items.last, and each item inside
 *   items.pages contain the following elements:
 *   - href: URL with appropriate query parameters for the item.
 *   - attributes: A keyed list of HTML attributes for the item.
 *   - text: The visible text used for the item link, such as "‹ Previous"
 *     or "Next ›".
 * - current: The page number of the current page.
 * - ellipses: If there are more pages than the quantity allows, then an
 *   ellipsis before or after the listed pages may be present.
 *   - previous: Present if the currently visible list of pages does not start
 *     at the first page.
 *   - next: Present if the visible list of pages ends before the last page.
 *
 * @see settings/settings.pager.yml
 * @see src/includes/navigation.inc
 * @see \Drupal\Core\Pager\PagerPreprocess::preprocessPager()
 */
#}

{#
  Attaching Drupal libraries
#}
{% block attachments %}
  {{ attach_library('brainsum_starterkit/pager') }}
{% endblock %}

{#
  Settings are loaded from settings/settings.pager.yml via preprocess.
  See src/includes/navigation.inc for details.
#}

{% if use_heading %}
  {% set pager_title_element = pagination_heading_level|default('h2') %}
{% else %}
  {% set pager_title_element = 'div' %}
{% endif %}

{#
  Building the template structure
#}
{% if items %}
  <nav class="c-pager{{ use_link_labels ? ' c-pager--labels' : ' c-pager--icons' }}" aria-labelledby="{{ heading_id }}">
    {# Heading for accessibility, see above for explanation #}
    <{{ pager_title_element }} id="{{ heading_id }}" class="visually-hidden">{{ 'Pagination'|t }}</{{ pager_title_element }}>

    <div class="c-pager__items js-pager__items">
      {# Print first item if we are not on the first page. #}
      {% if items.first %}
        <div class="c-pager__item c-pager__item--first">
          <a class="c-pager__link" href="{{ items.first.href }}" title="{{ 'Go to first page'|t }}"{{ items.first.attributes|without('href', 'title', 'class') }}>
            <span class="c-pager__text">
              <span class="visually-hidden">{{ 'First page'|t }}</span>
              {% if use_link_labels %}
                <span aria-hidden="true">{{ items.first.text|default('« First'|t) }}</span>
              {% else %}
                {{ include('brainsum_starterkit:icon', {
                  icon: 'angles-left-solid',
                  class: 'c-pager__icon c-pager__icon--first',
                  size: 16,
                  alt: 'Double left angles'|t,
                }) }}
              {% endif %}
            </span>
          </a>
        </div>
      {% endif %}

      {# Print previous item if we are not on the first page. #}
      {% if items.previous %}
        <div class="c-pager__item c-pager__item--previous">
          <a class="c-pager__link" href="{{ items.previous.href }}" title="{{ 'Go to previous page'|t }}" rel="prev"{{ items.previous.attributes|without('href', 'title', 'rel', 'class') }}>
            <span class="c-pager__text">
              <span class="visually-hidden">{{ 'Previous page'|t }}</span>
              {% if use_link_labels %}
                <span aria-hidden="true">{{ items.previous.text|default('‹ Previous page'|t) }}</span>
              {% else %}
                {{ include('brainsum_starterkit:icon', {
                  icon: 'angle-left-solid',
                  class: 'c-pager__icon c-pager__icon--previous',
                  size: 16,
                  alt: 'Single left angle'|t,
                }) }}
              {% endif %}
            </span>
          </a>
        </div>
      {% endif %}

      <ul class="c-pager__numbers c-pager__items">
        {# Add an ellipsis if there are further previous pages. #}
        {% if ellipses.previous %}
          <li class="c-pager__item c-pager__item--ellipsis" aria-hidden="true">
            <span class="c-pager__text">&hellip;</span>
          </li>
        {% endif %}

        {# Now generate the actual pager piece. #}
        {% for key, item in items.pages %}
          <li class="c-pager__item{{ current == key ? ' c-pager__item--active' : '' }} c-pager__item--number">
            {% if current == key %}
              {% set title = 'Current page'|t %}
            {% else %}
              {% set title = 'Go to page @key'|t({'@key': key}) %}
            {% endif %}

            {% if current != key %}
              <a class="c-pager__link" href="{{ item.href }}" title="{{ title }}"{{ item.attributes|without('href', 'title', 'class') }}>
            {% endif %}
              <span class="c-pager__text">
                <span class="visually-hidden">{{ 'Page'|t }}</span>{{- key -}}
              </span>
            {% if current != key %}
              </a>
            {% endif %}
          </li>
        {% endfor %}

        {# Add an ellipsis if there are further next pages. #}
        {% if ellipses.next %}
          <li class="c-pager__item c-pager__item--ellipsis" aria-hidden="true">
            <span class="c-pager__text">&hellip;</span>
          </li>
        {% endif %}
      </ul>

      {# Print next item if we are not on the last page. #}
      {% if items.next %}
        <div class="c-pager__item c-pager__item--next">
          <a class="c-pager__link" href="{{ items.next.href }}" title="{{ 'Go to next page'|t }}" rel="next"{{ items.next.attributes|without('href', 'title', 'rel', 'class') }}>
            <span class="c-pager__text">
              <span class="visually-hidden">{{ 'Next page'|t }}</span>
              {% if use_link_labels %}
                <span aria-hidden="true">{{ items.next.text|default('Next ›'|t) }}</span>
              {% else %}
                {{ include('brainsum_starterkit:icon', {
                  icon: 'angle-right-solid',
                  class: 'c-pager__icon c-pager__icon--next',
                  size: 16,
                  alt: 'Single right angle'|t,
                }) }}
              {% endif %}
            </span>
          </a>
        </div>
      {% endif %}

      {# Print last item if we are not on the last page. #}
      {% if items.last %}
        <div class="c-pager__item c-pager__item--last">
          <a class="c-pager__link" href="{{ items.last.href }}" title="{{ 'Go to last page'|t }}"{{ items.last.attributes|without('href', 'title', 'class') }}>
            <span class="c-pager__text">
              <span class="visually-hidden">{{ 'Last page'|t }}</span>
              {% if use_link_labels %}
                <span aria-hidden="true">{{ items.last.text|default('Last »'|t) }}</span>
              {% else %}
                {{ include('brainsum_starterkit:icon', {
                  icon: 'angles-right-solid',
                  class: 'c-pager__icon c-pager__icon--last',
                  size: 16,
                  alt: 'Double right angles'|t,
                }) }}
              {% endif %}
            </span>
          </a>
        </div>
      {% endif %}
    </div>
  </nav>
{% endif %}
