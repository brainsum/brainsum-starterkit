{#
/**
 * @file
 * Template for a generic layout.
 */
#}
{% set classes = [
  'o-layout',
  'o-layout--' ~ layout.id|clean_class,
] %}

{% if content %}
  <div{{ attributes.addClass(classes) }}>
    {% for region in layout.getRegionNames %}
      {% if content[region] %}
        <div {{ region_attributes[region].addClass('o-layout__region', 'o-layout__region--' ~ region|clean_class) }}>
          {{ content[region] }}
        </div>
      {% endif %}
    {% endfor %}
  </div>
{% endif %}
