{#
/**
 * @file
 * Theme override for a views mini-pager.
 *
 * Configuration:
 * To customize pager behavior, edit settings/settings.pager.yml:
 * - use_heading: Whether to use semantic heading or <div> for pager label.
 *   Default is false (uses <div>) because pagers are navigation elements,
 *   not content sections. Using headings pollutes the document outline with
 *   repetitive navigation that appears on multiple pages. Accessibility is
 *   maintained via aria-labelledby. Set to true only if you specifically
 *   need pager labels in the document outline.
 * - use_link_labels: Whether to use text labels or SVG icons for navigation
 *
 * Available variables:
 * - heading_id: Pagination heading ID for aria-labelledby.
 * - pagination_heading_level: Heading level from Drupal admin (default: h4).
 * - use_heading: Whether to use heading element (from settings.pager.yml).
 * - use_link_labels: Whether to use text labels vs icons (from settings.pager.yml).
 * - items: List of pager items (previous, current, next).
 *
 * @see settings/settings.pager.yml
 * @see src/includes/navigation.inc
 * @see template_preprocess_views_mini_pager()
 */
#}

{#
  Attaching Drupal libraries
#}
{% block attachments %}
  {{ attach_library('brainsum_starterkit/pager') }}
{% endblock %}

{% if use_heading %}
  {% set pager_title_element = pagination_heading_level|default('h2') %}
{% else %}
  {% set pager_title_element = 'div' %}
{% endif %}

{#
  Building the template structure
#}
{% if items.previous or items.next %}
  <nav class="c-pager c-pager--mini{{ use_link_labels ? ' c-pager--labels' : ' c-pager--icons' }}" aria-labelledby="{{ heading_id }}">
    {# Heading for accessibility #}
    <{{ pager_title_element }} id="{{ heading_id }}" class="visually-hidden">{{ 'Pagination'|t }}</{{ pager_title_element }}>

    <div class="c-pager__items js-pager__items">
      {% if items.previous %}
        <div class="c-pager__item c-pager__item--previous">
          <a class="c-pager__link" href="{{ items.previous.href }}" title="{{ 'Go to previous page'|t }}" rel="prev"{{ items.previous.attributes|without('href', 'title', 'rel', 'class') }}>
            <span class="c-pager__text">
              <span class="visually-hidden">{{ 'Previous page'|t }}</span>
              {% if use_link_labels %}
                <span aria-hidden="true">{{ items.previous.text|default('‹ Previous'|t) }}</span>
              {% else %}
                {{ include('brainsum_starterkit:icon', {
                  icon: 'angle-left-solid',
                  class: 'c-pager__icon c-pager__icon--previous',
                  size: 16,
                  alt: 'Single left angle'|t,
                }) }}
              {% endif %}
            </span>
          </a>
        </div>
      {% endif %}

      {% if items.current %}
        <div class="c-pager__item c-pager__item--current">
          <span class="c-pager__text">
            {% trans %}
              Page {{ items.current }}
            {% endtrans %}
          </span>
        </div>
      {% endif %}

      {% if items.next %}
        <div class="c-pager__item c-pager__item--next">
          <a class="c-pager__link" href="{{ items.next.href }}" title="{{ 'Go to next page'|t }}" rel="next"{{ items.next.attributes|without('href', 'title', 'rel', 'class') }}>
            <span class="c-pager__text">
              <span class="visually-hidden">{{ 'Next page'|t }}</span>
              {% if use_link_labels %}
                <span aria-hidden="true">{{ items.next.text|default('Next ›'|t) }}</span>
              {% else %}
                {{ include('brainsum_starterkit:icon', {
                  icon: 'angle-right-solid',
                  class: 'c-pager__icon c-pager__icon--next',
                  size: 16,
                  alt: 'Single right angle'|t,
                }) }}
              {% endif %}
            </span>
          </a>
        </div>
      {% endif %}
    </div>
  </nav>
{% endif %}
